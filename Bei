local startTimeSweep = tick()
local transConn
transConn = RunService.RenderStepped:Connect(function()
    if not sweepBar or not sweepBar.Parent then
        if transConn then transConn:Disconnect() end
        return
    end
    local elapsed = tick() - startTimeSweep
    local t = math.min(1, elapsed / sweepDuration)
    local alpha = 0.8 + 0.5 * math.sin(t * math.pi)
    sweepBar.BackgroundTransparency = alpha
    if t >= 1 then
        transConn:Disconnect()
        TweenService:Create(sweepBar, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
        task.delay(0.2, function() if sweepBar then sweepBar:Destroy() end end)
    end
end)

sweepMove.Completed:Connect(function()
    if transConn then transConn:Disconnect() end
    if sweepBar then
        TweenService:Create(sweepBar, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
        task.delay(0.2, function() if sweepBar then sweepBar:Destroy() end end)
    end
end)

