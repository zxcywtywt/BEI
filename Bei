local conn2
conn2 = RunService.RenderStepped:Connect(function()
    if not sweepBar or not sweepBar.Parent then
        if conn2 then conn2:Disconnect() end
        return
    end
    local barLeft = sweepBar.AbsolutePosition.X
    local barRight = barLeft + sweepBar.AbsoluteSize.X
    for i = 1, #letters do
        if not triggered[i] then
            local lbl = letterObjs[i]
            if lbl and lbl.Parent then
                local left = lbl.AbsolutePosition.X
                local right = left + lbl.AbsoluteSize.X
                if barRight > left and barLeft < right then
                    triggered[i] = true
                    TweenService:Create(lbl, TweenInfo.new(0.08), {TextColor3 = Color3.new(1,1,1)}):Play()
                    local origPos = lbl.Position
                    local jump = TweenService:Create(lbl, TweenInfo.new(0.12, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                        Position = UDim2.new(origPos.X.Scale, origPos.X.Offset, origPos.Y.Scale, origPos.Y.Offset - 8*scale)
                    })
                    jump:Play()
                    task.delay(0.1, function()
                        if lbl and lbl.Parent then TweenService:Create(lbl, TweenInfo.new(0.08), {Position = origPos}):Play() end
                    end)
                end
            end
        end
    end
    local lastLbl = letterObjs[#letters]
    if lastLbl and lastLbl.Parent then
        local lastRight = lastLbl.AbsolutePosition.X + lastLbl.AbsoluteSize.X
        if barRight >= lastRight then
            if conn2 then conn2:Disconnect() end
        end
    end
end)

