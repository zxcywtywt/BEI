local function playRingGlow()
    local startTime = tick()
    local conn
    conn = RunService.RenderStepped:Connect(function()
        local elapsed = tick() - startTime
        if elapsed >= GLOW_DURATION then
            conn:Disconnect()
            dotsContainer:Destroy()
            return
        end
        local p = elapsed / GLOW_DURATION
        local smoothP = p < 0.5 and (2 * p * p) or (1 - math.pow(-2 * p + 2, 2) / 2)
        local radius = RING_MAX_RADIUS * smoothP
        local angleOffset = math.rad(elapsed * 540)
        local angleStep = (math.pi * 2) / DOT_COUNT
        for i, dotObj in ipairs(dots) do
            local a = angleOffset + i * angleStep
            local alpha = 1 - math.abs((i - DOT_COUNT / 2) / (DOT_COUNT / 2))
            alpha = alpha * 0.85 + 0.15
            if p > 0.7 then
                alpha = alpha * (1 - (p - 0.7) / 0.3)
            end
            local x = math.cos(a) * radius
            local y = math.sin(a) * radius
            dotObj.Position = UDim2.fromOffset(x, y)
            dotObj.BackgroundTransparency = 1 - alpha
        end
    end)
end

